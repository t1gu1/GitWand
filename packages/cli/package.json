{
  "name": "@gitwand/cli",
  "version": "2.22.0",
  "description": "GitWand CLI — resolve Git conflicts from your terminal or CI pipeline",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "gitwand": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "keywords": [
    "git",
    "merge",
    "conflict",
    "conflict-resolution",
    "cli",
    "ci",
    "devtools",
    "gitwand"
  ],
  "homepage": "https://github.com/devlint/GitWand#cli",
  "bugs": {
    "url": "https://github.com/devlint/GitWand/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/devlint/GitWand.git",
    "directory": "packages/cli"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@gitwand/core": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "typescript": "^5.4.0",
    "vitest": "^4.1.0"
  },
  "author": "Laurent Guitton <lb.guitton@gmail.com>",
  "license": "MIT"
}
