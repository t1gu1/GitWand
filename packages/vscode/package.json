{
  "name": "gitwand-vscode",
  "displayName": "GitWand",
  "description": "Git's magic wand — automatic conflict resolution for VS Code",
  "version": "1.3.0",
  "publisher": "gitwand",
  "icon": "icon.png",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "SCM Providers",
    "Other"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/devlint/GitWand",
    "directory": "packages/vscode"
  },
  "homepage": "https://github.com/devlint/GitWand#readme",
  "bugs": {
    "url": "https://github.com/devlint/GitWand/issues"
  },
  "keywords": [
    "git",
    "merge",
    "conflict",
    "resolution",
    "diff",
    "rebase",
    "auto-resolve"
  ],
  "galleryBanner": {
    "color": "#1a1a24",
    "theme": "dark"
  },
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "gitwand.resolveFile",
        "title": "GitWand: Resolve Conflicts in Current File"
      },
      {
        "command": "gitwand.resolveAll",
        "title": "GitWand: Resolve All Trivial Conflicts"
      },
      {
        "command": "gitwand.status",
        "title": "GitWand: Show Conflict Status"
      }
    ],
    "configuration": {
      "title": "GitWand",
      "properties": {
        "gitwand.resolveWhitespace": {
          "type": "boolean",
          "default": true,
          "description": "Automatically resolve whitespace-only conflicts"
        },
        "gitwand.minConfidence": {
          "type": "string",
          "enum": [
            "certain",
            "high",
            "medium",
            "low"
          ],
          "default": "high",
          "description": "Minimum confidence level for auto-resolution"
        }
      }
    }
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "build": "node esbuild.mjs",
    "package": "pnpm run build && vsce package --no-dependencies",
    "publish": "pnpm run build && vsce publish --no-dependencies",
    "clean": "rm -rf dist *.vsix"
  },
  "dependencies": {
    "@gitwand/core": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^3.0.0",
    "esbuild": "^0.28.1",
    "typescript": "^5.4.0"
  },
  "license": "MIT"
}
