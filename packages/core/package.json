{
  "name": "@gitwand/core",
  "version": "2.12.0",
  "description": "GitWand core — automatic Git conflict resolution engine (powers @gitwand/cli, @gitwand/mcp, and the GitWand desktop app)",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "keywords": [
    "git",
    "merge",
    "conflict",
    "conflict-resolution",
    "diff3",
    "engine",
    "gitwand"
  ],
  "homepage": "https://github.com/devlint/GitWand#conflict-resolution-engine",
  "bugs": {
    "url": "https://github.com/devlint/GitWand/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/devlint/GitWand.git",
    "directory": "packages/core"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:bench": "vitest bench",
    "clean": "rm -rf dist"
  },
  "license": "MIT",
  "author": "Laurent Guitton <lb.guitton@gmail.com>",
  "peerDependencies": {
    "tree-sitter-wasms": ">=0.1.0",
    "web-tree-sitter": ">=0.20.0"
  },
  "peerDependenciesMeta": {
    "web-tree-sitter": {
      "optional": true
    },
    "tree-sitter-wasms": {
      "optional": true
    }
  },
  "dependencies": {
    "smol-toml": "^1.3.0",
    "yaml": "^2.5.0"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "tree-sitter-wasms": "^0.1.13",
    "typescript": "^5.4.0",
    "vitest": "^3.0.0",
    "web-tree-sitter": "~0.20.7"
  }
}
