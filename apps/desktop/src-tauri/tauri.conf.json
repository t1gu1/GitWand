{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-config-schema/schema.json",
  "productName": "GitWand",
  "version": "2.13.0",
  "identifier": "com.gitwand.desktop",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build"
  },
  "app": {
    "windows": [
      {
        "title": "GitWand \u2014 Git's magic wand",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "decorations": true,
        "transparent": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; style-src 'self' 'unsafe-inline'; script-src 'self' 'wasm-unsafe-eval'; connect-src 'self' ipc: http://ipc.localhost http://localhost:3001 http: https:; img-src 'self' data: blob: https: http:"
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "DeveloperTool",
    "shortDescription": "Automatic Git merge conflict resolution",
    "longDescription": "GitWand automatically detects and resolves trivial Git merge conflicts using deterministic pattern matching. Supports same-change, one-side-change, non-overlapping edits, whitespace-only diffs, and more.",
    "copyright": "Copyright (c) 2026 Laurent Guitton",
    "macOS": {
      "minimumSystemVersion": "10.15",
      "signingIdentity": null
    },
    "windows": {
      "wix": null
    },
    "linux": {
      "deb": {
        "depends": [
          "libwebkit2gtk-4.1-0",
          "libgtk-3-0"
        ]
      }
    }
  },
  "plugins": {
    "dialog": null,
    "shell": {
      "open": true
    },
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDczRTI4ODgxNDVFMzY0REEKUldUYVpPTkZnWWppYzBoOEFsSEN4elhHcENJRkxDZjV1VHM4M1hsbk4raFNOUVdCckowRFgwcS8K",
      "endpoints": [
        "https://github.com/devlint/GitWand/releases/latest/download/latest.json",
        "https://gitwand.devlint.fr/update/latest.json"
      ],
      "dialog": false
    }
  }
}